# NeuroTalk Backend — environment variables
# Copy this file to .env and fill in your values.

# ── App ──────────────────────────────────────────────────────
APP_NAME=NeuroTalk STT Backend
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── STT (faster-whisper) ─────────────────────────────────────
# Model sizes: tiny.en | base.en | small.en | medium.en | large-v3
# Smaller = faster, less accurate. tiny.en is 4x faster than small.en.
STT_MODEL_SIZE=small
# Device: cpu | cuda
STT_DEVICE=cpu
# Compute: int8 (fast CPU) | float16 (GPU) | float32 (slow CPU)
STT_COMPUTE_TYPE=int8
STT_BEAM_SIZE=1
STT_VAD_FILTER=true
STT_LANGUAGE=en

# Partial emit interval (ms) — lower = faster LLM trigger, more STT calls
STREAM_EMIT_INTERVAL_MS=800
# Minimum audio before emitting (ms) — lower = faster but more empty results
STREAM_MIN_AUDIO_MS=600

# ── Temp storage ─────────────────────────────────────────────
TEMP_DIR=.cache/audio

# ── TTS backend ──────────────────────────────────────────────
# Options: kokoro | chatterbox | qwen | vibevoice | omnivoice
# After changing, re-run: make backend-install TTS_BACKEND=<value>
TTS_BACKEND=kokoro

# Spoken greeting when a session starts. Set empty to disable.
WELCOME_MESSAGE=Hello! I'm your voice assistant. Go ahead and speak.

# ── LLM — Ollama (local, no API key required) ────────────────
# Prerequisites: brew install ollama && ollama pull gemma3:1b && ollama serve
# Fast options: gemma3:1b (default), llama3.2:1b, phi3.5
# Quality options: gemma4:latest, llama3.2, mistral
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=gemma3:1b
LLM_MAX_TOKENS=100
