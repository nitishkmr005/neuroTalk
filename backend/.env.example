# NeuroTalk Backend — environment variables
# Copy this file to .env and fill in your values.

# ── App ──────────────────────────────────────────────────────
APP_NAME=NeuroTalk STT Backend
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── STT (faster-whisper) ─────────────────────────────────────
# Model sizes: tiny.en | base.en | small.en | medium.en | large-v3
STT_MODEL_SIZE=small.en
# Device: cpu | cuda
STT_DEVICE=cpu
# Compute: int8 (fast CPU) | float16 (GPU) | float32 (slow CPU)
STT_COMPUTE_TYPE=int8
STT_BEAM_SIZE=1
STT_VAD_FILTER=true
STT_LANGUAGE=en
STREAM_EMIT_INTERVAL_MS=1200
STREAM_MIN_AUDIO_MS=900

# ── Temp storage ─────────────────────────────────────────────
TEMP_DIR=.cache/audio

# ── LLM — Ollama (local, no API key required) ────────────────
# Prerequisites: brew install ollama && ollama pull llama3.2 && ollama serve
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3.2
LLM_MAX_TOKENS=150
