APP_NAME=NeuroTalk STT Backend
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

STT_MODEL_SIZE=small
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_BEAM_SIZE=1
STT_VAD_FILTER=true
STT_LANGUAGE=
STREAM_EMIT_INTERVAL_MS=1200
STREAM_MIN_AUDIO_MS=900

TEMP_DIR=.cache/audio
